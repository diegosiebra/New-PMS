# ─── Application ─────────────────────────────────────────────────────────────
# HTTP port the NestJS server listens on (default: 3000)
PORT=3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Public URL of your Supabase project (required)
SUPABASE_URL=

# Service-role secret key — never expose this to the client (required)
SUPABASE_SERVICE_KEY=

# Direct PostgreSQL connection string used for migrations (optional)
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis server hostname (default: localhost)
REDIS_HOST=localhost

# Redis server port (default: 6379)
REDIS_PORT=6379

# Redis password — leave empty if no auth is configured (optional)
REDIS_PASSWORD=

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
# Base URL of the Evolution API instance (required)
EVOLUTION_API_URL=

# API key for authenticating requests to Evolution API (required)
EVOLUTION_API_KEY=

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Anthropic API key for Claude LLM integration (required)
ANTHROPIC_API_KEY=

# Claude model to use for AI automation agents (default: claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# ─── iCal Sync ────────────────────────────────────────────────────────────────
# How often (in minutes) to poll OTA iCal feeds for calendar updates (default: 15)
ICAL_SYNC_INTERVAL_MINUTES=15
